    <ex:has_alias rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Joan Elisabeth Lowther Murray</ex:has_alias>
    <ex:has_alias rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Joan Murray</ex:has_alias>
    <ex:has_birth_date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">1917-06-24</ex:has_birth_date>
