  <rdf:Description rdf:about="http://example.org/turing/joan_clarke">
    <rdf:type rdf:resource="http://example.org/turing/Person"/>
    <rdfs:label>Joan Clarke</rdfs:label>
    <rdfs:comment xml:lang="zh">Joan Elisabeth Lowther Murray, MBE was an English cryptanalyst and numismatist who worked as a code-breaker at Bletchley Park during the Second World War. Although she did not personally seek the spotlight, her role in the Enigma project that decrypted the German secret communications earned her awards and citations, such as appointment as a Member of the Order of the British Empire (MBE), in 1946.</rdfs:comment>
    <ex:born_in rdf:resource="http://example.org/turing/west_norwood"/>
    <ex:born_in rdf:resource="http://example.org/turing/west_norwood_london"/>
    <ex:died_in rdf:resource="http://example.org/turing/headington"/>
    <ex:has_alias rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Joan Clarke Murray</ex:has_alias>
