    <ex:has_alias rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Turing</ex:has_alias>
    <ex:has_birth_date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">1912-06-23</ex:has_birth_date>
