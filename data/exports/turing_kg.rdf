    <ex:has_death_date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">1954-06-07</ex:has_death_date>
    <ex:has_nationality rdf:datatype="http://www.w3.org/2001/XMLSchema#string">British</ex:has_nationality>
    <ex:has_alias rdf:datatype="http://www.w3.org/2001/XMLSchema#string">艾伦·图灵</ex:has_alias>
    <ex:born_in rdf:resource="http://example.org/turing/maida_vale"/>
    <ex:died_in rdf:resource="http://example.org/turing/wilmslow"/>
    <ex:studied_at rdf:resource="http://example.org/turing/kings_college_cambridge"/>
    <ex:studied_at rdf:resource="http://example.org/turing/princeton_university"/>
    <ex:worked_at rdf:resource="http://example.org/turing/bletchley_park"/>
    <ex:worked_at rdf:resource="http://example.org/turing/national_physical_laboratory"/>
    <ex:collaborated_with rdf:resource="http://example.org/turing/joan_clarke"/>
    <ex:collaborated_with rdf:resource="http://example.org/turing/alonzo_church"/>
    <ex:authored rdf:resource="http://example.org/turing/on_computable_numbers"/>
    <ex:authored rdf:resource="http://example.org/turing/computing_machinery_and_intelligence"/>
    <ex:proposed rdf:resource="http://example.org/turing/turing_machine"/>
    <ex:proposed rdf:resource="http://example.org/turing/turing_test"/>
    <ex:designed rdf:resource="http://example.org/turing/automatic_computing_engine"/>
    <ex:designed rdf:resource="http://example.org/turing/bombe_machine"/>
    <ex:contributed_to rdf:resource="http://example.org/turing/allied_codebreaking"/>
  </rdf:Description>
