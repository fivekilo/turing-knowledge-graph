    rdfs:label "Princeton" .

ex:proceedings_of_the_london_mathematical_society a ex:PublicationVenue ;
    rdfs:label "Proceedings of the London Mathematical Society" .

ex:second_world_war a ex:Event ;
    rdfs:label "Second World War" .

