@prefix ex: <http://example.org/turing/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:Concept a rdfs:Class,
        owl:Class ;
    rdfs:label "概念"@zh ;
    rdfs:comment "理论概念测试模型等抽象概念"@zh ;
    rdfs:subClassOf ex:Entity .

ex:Entity a rdfs:Class,
        owl:Class ;
    rdfs:label "实体"@zh ;
    rdfs:comment "知识图谱中的基础实体类型"@zh .

ex:Event a rdfs:Class,
        owl:Class ;
    rdfs:label "事件"@zh ;
    rdfs:comment "具有时间和背景的历史事件或项目"@zh ;
    rdfs:subClassOf ex:Entity .

ex:Field a rdfs:Class,
        owl:Class ;
    rdfs:label "学科"@zh ;
    rdfs:comment "知识领域或研究方向"@zh ;
    rdfs:subClassOf ex:Entity .

ex:Organization a rdfs:Class,
        owl:Class ;
    rdfs:label "机构"@zh ;
    rdfs:comment "学校机构研究机构等组织"@zh ;
    rdfs:subClassOf ex:Entity .

ex:Person a rdfs:Class,
        owl:Class ;
    rdfs:label "人物"@zh ;
    rdfs:comment "真实世界中的人物"@zh ;
    rdfs:subClassOf ex:Entity .

ex:Place a rdfs:Class,
        owl:Class ;
    rdfs:label "地点"@zh ;
    rdfs:comment "城市建筑地理位置等地点"@zh ;
    rdfs:subClassOf ex:Entity .

ex:PublicationVenue a rdfs:Class,
        owl:Class ;
    rdfs:label "发表载体"@zh ;
    rdfs:comment "论文发表的期刊或会议"@zh ;
    rdfs:subClassOf ex:Entity .

ex:Work a rdfs:Class,
        owl:Class ;
    rdfs:label "作品"@zh ;
    rdfs:comment "论文文章等知识作品"@zh ;
    rdfs:subClassOf ex:Entity .

ex:alan_turing a ex:Person ;
    rdfs:label "Alan Turing" ;
    ex:authored ex:on_computable_numbers ;
    ex:born_in ex:maida_vale,
        ex:warrington_lodge ;
    ex:died_in ex:wilmslow ;
    ex:has_alias "Alan M. Turing"^^xsd:string,
        "Alan Mathieson Turing"^^xsd:string,
        "Alan Mathison Turing"^^xsd:string,
        "Turing"^^xsd:string ;
    ex:has_birth_date "1912-06-23"^^xsd:date ;
    ex:has_death_date "1954-06-07"^^xsd:date ;
    ex:has_nationality "United Kingdom"^^xsd:string ;
    ex:proposed ex:turing_machine,
        ex:turing_test ;
    ex:related_to_field ex:computer_science,
        ex:cryptanalysis,
        ex:cryptography,
        ex:logic,
        ex:mathematical_and_theoretical_biology,
        ex:mathematics,
        ex:theoretical_computer_science ;
    ex:studied_at ex:hazlehurst_community_primary_school,
        ex:king_s_college,
        ex:princeton_university,
        ex:sherborne_school ;
    ex:worked_at ex:government_code_and_cypher_school,
        ex:government_communications_headquarters,
        ex:national_physical_laboratory,
        ex:university_of_cambridge,
        ex:university_of_manchester,
        ex:victoria_university_of_manchester ;
    rdfs:comment "Alan Mathison Turing was an English mathematician, computer scientist, logician, cryptanalyst, philosopher and theoretical biologist. He was highly influential in the development of theoretical computer science, providing a formalisation of the concepts of algorithm and computation with the Turing machine, which can be considered a model of a general-purpose computer. Turing is widely considered to be the father of theoretical computer science."@zh .

ex:alonzo_church a ex:Person ;
    rdfs:label "Alonzo Church" ;
    ex:born_in ex:washington_d_c ;
    ex:died_in ex:hudson,
        ex:hudson_ohio ;
    ex:has_birth_date "1903-06-14"^^xsd:date ;
    ex:has_death_date "1995-08-11"^^xsd:date ;
    ex:has_nationality "United States"^^xsd:string ;
    ex:related_to_field ex:computer_science,
        ex:logic,
        ex:mathematical_logic,
        ex:mathematics,
        ex:theoretical_computer_science ;
    ex:studied_at ex:harvard_university,
        ex:princeton_university,
        ex:university_of_amsterdam,
        ex:university_of_g_ttingen ;
    ex:worked_at ex:princeton_university,
        ex:ucla,
        ex:university_of_california_los_angeles ;
    rdfs:comment "Alonzo Church was an American computer scientist, mathematician, logician, and philosopher who made major contributions to mathematical logic and the foundations of theoretical computer science. He is best known for the lambda calculus, the Church–Turing thesis, proving the unsolvability of the Entscheidungsproblem, the Frege–Church ontology, and the Church–Rosser theorem. Alongside his doctoral student Alan Turing, Church is considered one of the founders of computer science."@zh .

ex:authored a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "撰写"@zh ;
    rdfs:comment "人物撰写作品"@zh ;
    rdfs:domain ex:Person ;
    rdfs:range ex:Work .

ex:bletchley_park a ex:Organization ;
    rdfs:label "Bletchley Park" ;
    ex:has_alias "Station X"^^xsd:string ;
    ex:has_year "1877"^^xsd:gYear ;
    ex:located_in ex:buckinghamshire ;
    rdfs:comment "Bletchley Park is an English country house and estate in Bletchley, Milton Keynes (Buckinghamshire), that became the principal centre of Allied code-breaking during the Second World War. During World War II, the estate housed the Government Code and Cypher School (GC&CS), which regularly penetrated the secret communications of the Axis powers – most importantly the German Enigma and Lorenz ciphers. The GC&CS team of codebreakers included John Tiltman, Dilwyn Knox, Alan Turing, Harry Golombek, Gordon Welchman, Hugh Alexander, Donald Michie, Bill Tutte and Stuart Milner-Barry."@zh .

ex:born_in a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "出生于"@zh ;
    rdfs:comment "人物出生地点"@zh ;
    rdfs:domain ex:Person ;
    rdfs:range ex:Place .

ex:contributed_to a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "贡献于"@zh ;
    rdfs:comment "人物参与或贡献的事件项目"@zh ;
    rdfs:domain ex:Person ;
    rdfs:range ex:Event .

ex:died_in a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "逝世于"@zh ;
    rdfs:comment "人物逝世地点"@zh ;
    rdfs:domain ex:Person ;
    rdfs:range ex:Place .

ex:has_alias a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "别名"@zh ;
    rdfs:comment "实体的别名或简称"@zh ;
    rdfs:domain ex:Entity ;
    rdfs:range rdfs:Literal .

ex:has_birth_date a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "出生日期"@zh ;
    rdfs:comment "人物出生日期"@zh ;
    rdfs:domain ex:Person ;
    rdfs:range rdfs:Literal .

ex:has_death_date a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "逝世日期"@zh ;
    rdfs:comment "人物逝世日期"@zh ;
    rdfs:domain ex:Person ;
    rdfs:range rdfs:Literal .

ex:has_nationality a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "国籍"@zh ;
    rdfs:comment "人物国籍"@zh ;
    rdfs:domain ex:Person ;
    rdfs:range rdfs:Literal .

ex:has_year a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "年份"@zh ;
    rdfs:comment "实体相关年份"@zh ;
    rdfs:domain ex:Entity ;
    rdfs:range rdfs:Literal .

ex:joan_clarke a ex:Person ;
    rdfs:label "Joan Clarke" ;
    ex:born_in ex:west_norwood,
        ex:west_norwood_london ;
    ex:contributed_to ex:second_world_war ;
    ex:died_in ex:headington ;
    ex:has_alias "Joan Clarke Murray"^^xsd:string,
        "Joan Elisabeth Lowther Clarke"^^xsd:string,
        "Joan Elisabeth Lowther Clarke Murray"^^xsd:string,
        "Joan Elisabeth Lowther Murray"^^xsd:string,
        "Joan Murray"^^xsd:string ;
    ex:has_birth_date "1917-06-24"^^xsd:date ;
    ex:has_death_date "1996-09-04"^^xsd:date ;
    ex:has_nationality "United Kingdom"^^xsd:string,
        "United Kingdom of Great Britain and Ireland"^^xsd:string ;
    ex:related_to_field ex:cryptography ;
    ex:studied_at ex:dulwich_college,
        ex:newnham_college ;
    ex:worked_at ex:government_communications_headquarters ;
    rdfs:comment "Joan Elisabeth Lowther Murray, MBE was an English cryptanalyst and numismatist who worked as a code-breaker at Bletchley Park during the Second World War. Although she did not personally seek the spotlight, her role in the Enigma project that decrypted the German secret communications earned her awards and citations, such as appointment as a Member of the Order of the British Empire (MBE), in 1946."@zh .

ex:located_in a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "位于"@zh ;
    rdfs:comment "实体所处地点"@zh ;
    rdfs:domain ex:Entity ;
    rdfs:range ex:Place .

ex:proposed a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "提出"@zh ;
    rdfs:comment "人物提出某个理论或概念"@zh ;
    rdfs:domain ex:Person ;
    rdfs:range ex:Concept .

ex:published_in a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "发表于"@zh ;
    rdfs:comment "作品发表的期刊或载体"@zh ;
    rdfs:domain ex:Work ;
    rdfs:range ex:PublicationVenue .

ex:related_to_field a rdf:Property,
        owl:ObjectProperty ;
